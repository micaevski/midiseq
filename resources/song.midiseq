UP_DOWN(t,d,max):
$t 
CC74 val=mod1
if trans < $max
    UP_DOWN($t,$d,$max)! 2 trans=$d mod1+=10
else
    DOWN_UP($t,$d,$max)! 2 trans=-$d     
 

DOWN_UP(t,d,max):
$t
CC74 val=mod1 
if trans > -$max 
    DOWN_UP($t,$d,$max)! 2 trans=-$d mod1-=10
else    
    UP_DOWN($t,$d,$max)! 2 trans=$d 


MELODY:
P3O4 1


UP_DOWN(MELODY, 3d, 12)! chan=1 scale=GM