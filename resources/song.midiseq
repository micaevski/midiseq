UP(t,d,max):
$t 
if trans < $max
    UP($t,$d,$max)! 2 trans=$d
else
    DOWN($t,$d,$max)! 2 trans=-$d 

DOWN(t,d,max):
$t 
if trans > -$max
    DOWN($t,$d,$max)! 2 trans=-$d
else
    UP($t,$d,$max)! 2 trans=$d 

