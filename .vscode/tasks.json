{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "MidiSeq Debug",
			"type": "shell",
			"command": "odin",
			"args": ["build", "source", "-debug", "-out:build/midiseq"],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "MidiSeq Release",
			"type": "shell",
			"command": "odin",
			"args": ["build", "source", "-o:speed", "-disable-assert", "-out:build/midiseq-release"],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "MidiSeq Debug Optimized",
			"type": "shell",
			"command": "odin",
			"args": ["build", "source", "-o:speed", "-debug", "-out:build/midiseq-relwithdebinfo"],
			"group": "build",
			"problemMatcher": []
		}
	]
}
